{
  "expo": {
    "name": "ProofVault",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.proofvault.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ProofVault uses the camera to scan receipts and capture proof of purchase."
      }
    },
    "android": {
      "package": "com.proofvault.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {}
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "ProofVault uses the camera to scan receipts and capture proof of purchase."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
