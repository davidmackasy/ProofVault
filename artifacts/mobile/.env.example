EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: enable dev mock purchases (local only, __DEV__ only)
# EXPO_PUBLIC_USE_MOCK_PURCHASES=false

# Receipt reading backend (Supabase Edge Function secrets — never in the app):
#
# 1. Create a Google Cloud project and enable Document AI API
# 2. Create an Expense Parser processor (Document AI → Create processor → Expense)
# 3. Create a service account with Document AI User role; download JSON key
# 4. Deploy:
#      supabase db push
#      supabase secrets set GOOGLE_CLOUD_PROJECT_ID=your-project-id
#      supabase secrets set GOOGLE_DOCUMENTAI_LOCATION=us
#      supabase secrets set GOOGLE_DOCUMENTAI_PROCESSOR_ID=your-processor-id
#      supabase secrets set GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
#      supabase functions deploy extract-receipt
# 5. In Supabase Dashboard → Authentication → Providers → enable Anonymous sign-in
#    (allows receipt scanning before email sign-up)
